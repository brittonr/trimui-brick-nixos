	thermal-zones {

		cpul_thermal_zone {
			polling-delay-passive = <0x64>;
			polling-delay = <0x3e8>;
			thermal-sensors = <0x12 0x01>;
			sustainable-power = <0x4b0>;
			phandle = <0x118>;

			trips {
				phandle = <0x119>;

				trip-point@0 {
					temperature = <0xea60>;
					type = "passive";
					hysteresis = <0x00>;
					phandle = <0x11a>;
				};

				trip-point@1 {
					temperature = <0x11170>;
					type = "passive";
					hysteresis = <0x00>;
					phandle = <0x13>;
				};

				cpu_crit@0 {
					temperature = <0x19a28>;
					type = "critical";
					hysteresis = <0x00>;
					phandle = <0x11b>;
				};
			};

			cooling-maps {

				map0 {
					trip = <0x13>;
					cooling-device = <0x09 0xffffffff 0xffffffff>;
					contribution = <0x400>;
				};
			};
		};

