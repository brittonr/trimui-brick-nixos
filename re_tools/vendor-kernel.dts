	psci {
		compatible = "arm,psci-1.0";
		method = "smc";
	};

	dcxo24M_clk {
		#clock-cells = <0x00>;
		compatible = "fixed-clock";
		clock-frequency = <0x16e3600>;
		clock-output-names = "dcxo24M";
		phandle = <0x22>;
	};

	rc16m_clk {
		#clock-cells = <0x00>;
		compatible = "fixed-clock";
		clock-frequency = <0xf42400>;
		clock-accuracy = <0x11e1a300>;
		clock-output-names = "rc-16m";
		phandle = <0x24>;
	};

	ext32k_clk {
		#clock-cells = <0x00>;
