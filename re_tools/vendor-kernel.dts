				phandle = <0x10f>;

				queue0 {
				};
			};

			tx_queues-config {
				snps,tx-queues-to-use = <0x01>;
				phandle = <0x110>;

				queue0 {
				};
			};

			mdio1@1 {
				compatible = "snps,dwmac-mdio";
				#address-cells = <0x01>;
				#size-cells = <0x00>;
				phandle = <0x233>;

				ethernet-phy@1 {
					compatible = "ethernet-phy-ieee802.3-c22";
					reg = <0x01>;
					max-speed = <0x3e8>;
					reset-gpios = <0x59 0x09 0x1b 0x01>;
					reset-assert-us = <0x2710>;
					reset-deassert-us = <0x249f0>;
					phandle = <0x10d>;
				};
			};
		};

		ioserial@0 {
			compatible = "allwinner,ioserial-100";
			tx-gpios = <0x59 0x01 0x0b 0x00>;
			status = "disabled";
		};

		sid@3006000 {
			compatible = "allwinner,sun55iw3p1-sid", "allwinner,sunxi-sid";
			reg = <0x00 0x3006000 0x00 0x1000>;
			#address-cells = <0x01>;
			#size-cells = <0x01>;
			non-secure-maxoffset = <0x80>;
			non-secure-maxlen = <0x20>;

			secure_status {
				reg = <0x00 0x00>;
				offset = <0xa0>;
				size = <0x04>;
			};

			chipid {
				reg = <0x00 0x00>;
				offset = <0x200>;
				size = <0x10>;
			};

			rotpk {
				reg = <0x00 0x00>;
				offset = <0x140>;
				size = <0x20>;
			};
		};

		sram_ctrl@3000000 {
			compatible = "allwinner,sram_ctrl";
			reg = <0x00 0x3000000 0x00 0x184>;
			phandle = <0x234>;

			soc_ver {
				offset = <0x24>;
				mask = <0x07>;
				shift = <0x00>;
				ver_a = <0x00>;
				ver_b = <0x01>;
				ver_c = <0x02>;
			};

			soc_id {
				offset = <0x200>;
				mask = <0x01>;
				shift = <0x16>;
			};

			soc_bin {
				offset = <0x00>;
				mask = <0x3ff>;
				shift = <0x00>;
			};
		};

		auto_print@54321 {
			reg = <0x00 0x54321 0x00 0x00>;
			device_type = "auto_print";
			status = "okay";
		};

